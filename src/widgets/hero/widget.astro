---
import { ArrowUpRight } from "lucide-react";
import { motion } from "motion/react";
import type { Language, Translations } from "@/i18n/utils";

interface Props {
  lang: Language;
  t: Translations;
}

const { lang, t } = Astro.props;

const blogPosts = [
  {
    number: "02",
    title: "Mountain Sounds",
    date: "January 27, 12:24 PM",
    image:
      "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&q=80&w=400",
  },
  {
    number: "03",
    title: "The Bahamas",
    date: "January 27, 12:24 PM",
    image:
      "https://images.unsplash.com/photo-1548574505-5e239809ee19?auto=format&fit=crop&q=80&w=400",
  },
  {
    number: "04",
    title: "Singita Sabi Sand",
    date: "January 27, 12:24 PM",
    image:
      "https://images.unsplash.com/photo-1516426122078-c23e76319801?auto=format&fit=crop&q=80&w=400",
  },
];
---

<section
  class="relative min-h-screen flex items-center overflow-hidden bg-black"
>
  <!-- Main Background Image -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero_bg.png"
      alt="Hero Background"
      class="w-full h-full object-cover opacity-80"
    />
    <div
      class="absolute inset-0 bg-linear-to-r from-black/60 via-black/30 to-transparent"
    >
    </div>
    <div
      class="absolute inset-0 bg-linear-to-t from-black/80 via-transparent to-black/40"
    >
    </div>
  </div>

  <div class="container mx-auto px-6 relative z-10 pt-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Left Content -->
      <div class="lg:col-span-7">
        <motion.div
          initial={{ opacity: 0, x: -30 }}
          animate={{ opacity: 1, x: 0 }}
          transition={{ duration: 0.8 }}
          client:load
        >
          <h1
            class="text-white text-5xl md:text-7xl font-bold leading-[1.05] tracking-tight"
          >
            NEVER STOP <br />
            EXPLORING THE <br />
            WORLD
          </h1>

          <p
            class="mt-8 text-white/70 text-sm md:text-base leading-relaxed max-w-xl font-light"
          >
            Lorem ipsum dolor sit amet consectetur. Tellus cursus at nulla in ut
            feugiat vestibulum. Ac ultrices pellentesque pulvinar pellentesque
            tellus at uii feugiat vestibulum. Tellus cursus at nulla in ut
            feugiât vestibulum. Ac ultrices pellentesque pulvinar pellentesque
            tellus at vel.
          </p>

          <div class="mt-10 flex flex-wrap gap-4 items-center">
            <a
              href={`/${lang}/contact`}
              class="bg-[hsl(140,60%,45%)] hover:bg-[hsl(140,60%,40%)] text-white px-8 py-4 rounded-full font-semibold flex items-center gap-3 group transition-all"
            >
              CONTACT US
              <div
                class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center"
              >
                <ArrowUpRight
                  className="w-4 h-4 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"
                />
              </div>
            </button>
          </div>
        </motion.div>
      </div>

      <!-- Right Content: Blog Post Cards -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        {
          blogPosts.map((post, index) => (
            <motion.a
              href="/blog"
              initial={{ opacity: 0, x: 30 }}
              animate={{ opacity: 1, x: 0 }}
              transition={{ duration: 0.6, delay: 0.2 + index * 0.1 }}
              className="group relative flex items-center bg-[#1A1A1A] border border-white/5 rounded-[3rem] overflow-hidden transition-all cursor-pointer"
              client:load
            >
              <div class="flex items-center gap-6 px-8 py-5 w-full relative z-10"> 
                <!-- Text Content -->
                <div class="flex flex-col gap-1">
                  <h3 class="text-white font-bold tracking-tight leading-tight transition-colors">
                    {post.title.split(" ").map((word, i, arr) => (
                      <>
                        {word} {i === 0 && arr.length > 1 && <br />}
                      </>
                    ))}
                  </h3>
                  <p class="text-white/40 text-[11px] font-semibold tracking-widest uppercase leading-relaxed mt-3 max-w-[100px]">
                    {post.date}
                  </p>
                </div>
              </div>

              <!-- Card Image with fade -->
              <div class="absolute right-0 top-0 bottom-0 w-[60%] overflow-hidden">
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000"
                />
                <div class="absolute inset-0 bg-linear-to-r from-[#1A1A1A] via-[#1A1A1A]/90 to-transparent" />
              </div>
            </motion.a>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Design Accent: Bottom curved white divider if any? Image shows only header/hero -->
  <!-- <div class="absolute bottom-0 left-0 w-full h-24 bg-gradient-to-t from-black to-transparent z-10"></div> -->
</section>

<style>
  h1 {
    font-family: "Geist", sans-serif;
    letter-spacing: -0.02em;
  }
</style>
