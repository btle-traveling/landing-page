---
import {
  FacebookIcon,
  InstagramIcon,
  TwitterIcon,
  YoutubeIcon,
} from "lucide-react";
import { Separator } from "@/components/ui/separator";
import type { Language, Translations } from "@/i18n/utils";
import { AppLogo } from "../logo/widget";

interface Props {
  lang: Language;
  t: Translations;
}

const { lang, t } = Astro.props;
---

<footer class="w-full text-foreground z-50">
  <div
    class="container mx-auto flex items-center justify-between gap-3 px-4 py-4 max-md:flex-col sm:px-6 sm:py-6 md:gap-6 md:py-8"
  >
    <a href={`/${lang}/`}>
      <div class="flex items-center gap-3">
        <AppLogo />
      </div>
    </a>

    <div class="flex items-center gap-5 whitespace-nowrap">
      <a href={`/${lang}/#about-us`}>{t.footer.about}</a>
      <a href={`/${lang}/#features`}>{t.footer.features}</a>
      <a href="#">{t.footer.works}</a>
      <a href="#">{t.footer.career}</a>
    </div>

    <div class="flex items-center gap-4">
      <a href="#">
        <FacebookIcon />
      </a>
      <a href="#">
        <InstagramIcon />
      </a>
      <a href="#">
        <TwitterIcon />
      </a>
      <a href="#">
        <YoutubeIcon />
      </a>
    </div>
  </div>

  <Separator />

  <div
    class="mx-auto flex w-full flex-col items-center justify-center gap-4 px-4 py-8 sm:px-6 sm:flex-row sm:justify-between"
  >
    <p
      class="text-center font-medium text-balance text-sm text-muted-foreground"
    >
      {`©${new Date().getFullYear()}`}
      <a href={`/${lang}/`} class="hover:underline">SkySearch</a>. {
        t.footer.copyright
      }
    </p>

    <div
      class="flex items-center gap-4 text-sm font-medium text-muted-foreground"
    >
      <a
        href="/SkySearch_AI_Privacy_Policy.pdf"
        class="hover:underline hover:text-foreground transition-colors"
        target="_blank"
      >
        {t.footer.privacyPolicy}
      </a>
      <a
        href="/SkySearch_AI_Terms_of_Service.pdf"
        target="_blank"
        class="hover:underline hover:text-foreground transition-colors"
      >
        {t.footer.termsOfService}
      </a>
    </div>
  </div>
</footer>
