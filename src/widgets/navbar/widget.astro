---
import type { Language, Translations } from "@/i18n/utils";
import AppLogo from "@/widgets/logo/widget.astro";
import { MobileNavbar } from "./mobile-widget";

interface Props {
  lang: Language;
  t: Translations;
}

const { lang, t } = Astro.props;

const navigationItems = [
  {
    title: t.nav.features,
    href: `/${lang}/#features`,
  },
  {
    title: t.nav.aboutUs,
    href: `/${lang}/#about-us`,
  },
  {
    title: t.nav.contactUs,
    href: `/${lang}/#contact-us`,
  },
  {
    title: "Blog",
    href: `/${lang}/blog`,
  },
];
---

<header class="absolute top-0 left-0 z-50 w-full py-6">
  <div class="container mx-auto flex items-center justify-between px-6">
    <AppLogo lang={lang} />

    <nav class="hidden md:flex items-center gap-8">
      {
        navigationItems.map((item) => (
          <a
            href={item.href}
            class="text-white/80 hover:text-white text-[11px] font-bold tracking-[0.2em] transition-colors uppercase"
          >
            {item.title}
          </a>
        ))
      }
    </nav>

    <!-- Mobile Menu Button -->
    <div class="md:hidden">
      <MobileNavbar client:load />
    </div>
  </div>
</header>
